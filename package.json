{
  "name": "ulid-b64",
  "main": "dist/node.js",
  "browser": "dist/browser.js",
  "version": "0.2.3",
  "description": "ULID as a binary, or as a base64-like sortable string",
  "keywords": [
    "ulid",
    "base64",
    "id",
    "guid",
    "uuid",
    "uuidv7",
    "binary"
  ],
  "engines": {
    "node": ">=16"
  },
  "files": [
    "dist/**/*",
    "index.d.ts",
    "LICENSE.txt"
  ],
  "scripts": {
    "bench": "npm run build && node bench",
    "build": "ts-node build.ts",
    "fix": "run-s fix:js fix:json",
    "fix:js": "eslint --ext .cjs,.js,.ts --fix .",
    "fix:json": "prettier --write .",
    "lint": "run-p lint:js lint:json",
    "lint:js": "eslint --ext .cjs,.js,.ts .",
    "lint:json": "prettier --check .",
    "prebuild": "rimraf ./dist",
    "prepublishOnly": "run-s validate && npm run build",
    "preversion": "npm run validate",
    "validate": "npm run lint && npm run test",
    "test": "jest"
  },
  "author": "ooxif",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ooxif/ulid-b64.js.git"
  },
  "bugs": {
    "url": "https://github.com/ooxif/ulid-b64.js/issues"
  },
  "homepage": "https://github.com/ooxif/ulid-b64.js#readme",
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.4",
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "esbuild": "^0.27.3",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-gitignore": "^0.1.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.2.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
